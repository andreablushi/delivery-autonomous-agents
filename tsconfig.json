{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "allowJs": true
  },
  "include": ["src/**/*.ts", "src/**/*.js", "test.ts"]
}
