{
  "name": "autonomous-software-agents",
  "version": "1.0.0",
  "description": "A project focused on the development and analysis of autonomous software agents, exploring their design, implementation, and applications in the Deliveroo.js domain, for the University of Trento.",
  "homepage": "https://github.com/andreablushi/autonomous-software-agents#readme",
  "bugs": {
    "url": "https://github.com/andreablushi/autonomous-software-agents/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreablushi/autonomous-software-agents.git"
  },
  "license": "ISC",
  "author": "Andrea Blushi, Davide Donà",
  "type": "module",
  "main": "src/index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node --import tsx --env-file-if-exists=.env src/index.ts",
    "start:competitive": "cross-env COMPETITIVE=true node --import tsx --env-file-if-exists=.env src/index.ts",
    "dev": "cross-env NODE_ENV=development node --import tsx --env-file-if-exists=.env src/index.ts",
    "dev:competitive": "cross-env NODE_ENV=development COMPETITIVE=true node --import tsx --env-file-if-exists=.env src/index.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@unitn-asa/deliveroo-js-sdk": "^1.3.0",
    "@unitn-asa/pddl-client": "^0.0.37",
    "cross-env": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
