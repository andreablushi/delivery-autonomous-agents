
# Environment variables for agent connection
# Remote API URL (uncomment if you want to use the remote server)
# HOST=https://deliveroojs.bears.disi.unitn.it
HOST=http://localhost:8080


# LLM provider — required when AGENT_KIND=llm
LLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LLM_API_KEY=YOUR_LLM_API_KEY_HERE



# Messages for the LLM agent are emitted by a specific sender (e.g., the mission emitter). 
# If MISSION_EMITTER_NAME or MISSION_EMITTER_ID are set, only messages from that sender will be processed. 
# Otherwise, all messages will be processed.
MISSION_EMITTER_NAME=MISSION_EMITTER_NAME_HERE
MISSION_EMITTER_ID=


# PDDL solver mode: set PAAS_HOST to use the online solver; leave unset to use the local binary.
# When set, the agent uses the @unitn-asa/pddl-client online solver at this URL instead of the
# local dual-bfws-ffparser binary (~/.planutils/bin/) — no planutils install needed.
# PAAS_HOST=https://solver.planning.domains:5001


# Debug logging — comma-separated namespaces, or * for all. Leave empty to silence debug output.
# Available namespaces: perceive, deliberate, desire, intention, plan, pddl, execute, map, api, llm, llm-client, llm-prompt, comm
# Examples:
#   DEBUG=*                  # everything
#   DEBUG=plan,execute       # only planning + execution
#   DEBUG=perceive,map       # only belief updates
# warn/error are always emitted regardless of this setting.
_DEBUG=


# Authentication token for the single BDI agent, single-agent mode (npm start / npm run dev)
BDI_TOKEN=YOUR_TOKEN_HERE
# Player ID bound to BDI_TOKEN. Used in cooperative mode so the LLM agent recognises
# the BDI agent as a teammate by ID (team-name matching is not used).
BDI_ID=YOUR_BDI_AGENT_ID_HERE


# Authentication tokens for LLM agents, LLM mode (npm run dev:llm)
LLM_TOKEN=YOUR_LLM_AGENT_TOKEN_HERE
# Player ID bound to LLM_TOKEN. Used in cooperative mode so the BDI agent recognises
# the LLM agent as a teammate by ID.
LLM_ID=YOUR_LLM_AGENT_ID_HERE


# Competitive mode (npm run competitive / npm run dev:competitive)
# Add one COMPETITIVE_TOKEN_N per agent you want to spawn; remove any you don't need.
COMPETITIVE_TOKEN_1=YOUR_TOKEN_1_HERE
COMPETITIVE_TOKEN_2=YOUR_TOKEN_2_HERE



