
# Environment variables for agent connection
# Remote API URL (uncomment if you want to use the remote server)
# HOST= https://deliveroojs.bears.disi.unitn.it
HOST=http://localhost:8080

# Authentication token for the agent, single-agent mode (npm start / npm run dev)
TOKEN=YOUR_TOKEN_HERE

# Competitive mode (npm run competitive / npm run dev:competitive)
# Add one TOKEN_N per agent you want to spawn; remove any you don't need
TOKEN_1=YOUR_TOKEN_1_HERE
TOKEN_2=YOUR_TOKEN_2_HERE

# PDDL planner URL (defaults to https://solver.planning.domains:5001 if unset)
# Set to local Docker instance to avoid the remote solver
PAAS_HOST='http://localhost:5001'


